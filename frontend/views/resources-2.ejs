    <link href="https://fonts.googleapis.com/css2?family=Public+Sans:wght@300;400;500;600;700;800&amp;family=JetBrains+Mono:wght@400;500&amp;display=swap" rel="stylesheet">
    <style>
        :root {
            --charcoal: #1a1a1a;
            --graphite: #2a2a2a;
            --teal-accent: #10b981;
            --border-gray: #333333;
        }

        body {
            font-family: 'Public Sans', sans-serif;
            background-color: var(--charcoal);
            color: #e5e5e5;
            -webkit-font-smoothing: antialiased;
        }

        .mono {
            font-family: 'JetBrains Mono', monospace;
            font-variant-numeric: tabular-nums;
        }

        .industrial-border {
            border: 1px solid var(--border-gray);
        }

        .input-field {
            @apply w-full bg-[#161616] border border-[#333] px-3 py-2 text-xs text-white focus:outline-none focus:border-[#10b981] transition-colors rounded-[2px];
        }

        .status-pill {
            @apply px-2 py-0.5 text-[10px] font-bold uppercase tracking-tighter rounded-[2px] inline-flex items-center gap-1;
        }

        .btn-primary {
            @apply bg-[#10b981] hover:bg-[#0d9469] text-white font-bold py-2.5 px-4 text-[10px] uppercase tracking-widest transition-all rounded-[2px] active:scale-[0.98] disabled:opacity-50 disabled:cursor-not-allowed;
        }

        .btn-secondary {
            @apply border border-[#333] hover:border-white text-gray-400 hover:text-white font-bold py-2 px-4 text-[10px] uppercase tracking-widest transition-all rounded-[2px];
        }

        /* Timeline Specifics */
        .timeline-grid {
            display: grid;
            grid-template-columns: 180px repeat(30, 80px);
        }

        .timeline-cell {
            @apply border-r border-[#333] h-12 flex items-center justify-center text-[10px] font-bold text-gray-600;
        }

        .booking-block {
            @apply absolute h-8 mt-2 rounded-[2px] text-[9px] font-bold px-2 flex items-center border overflow-hidden whitespace-nowrap z-10;
        }

        .conflict-overlay {
            @apply absolute inset-0 bg-red-500/10 border-2 border-red-500/40 z-20 pointer-events-none flex items-center justify-center;
        }

        /* Custom Scrollbar */
        ::-webkit-scrollbar { width: 6px; height: 6px; }
        ::-webkit-scrollbar-track { background: var(--charcoal); }
        ::-webkit-scrollbar-thumb { background: var(--border-gray); }
        ::-webkit-scrollbar-thumb:hover { background: var(--teal-accent); }
    </style>
</head>
