    <script>
        // Populate Timeline Headers
        const grid = document.querySelector('.timeline-grid');
        const headerCells = [];
        for (let i = 1; i <= 30; i++) {
            const dayStr = i < 10 ? `0${i}` : i;
            const cell = document.createElement('div');
            cell.className = 'timeline-cell bg-[#131313] border-b border-[#333]';
            cell.innerText = `MAY ${dayStr}`;
            headerCells.push(cell);
        }
        // Insert after the first header cell
        grid.insertBefore(headerCells[0], grid.children[1]);
        for(let i=1; i<headerCells.length; i++) {
            grid.insertBefore(headerCells[i], headerCells[i-1].nextSibling);
        }

        // Simple Notification Logic
        const submitBtn = document.getElementById('submit-booking-btn');
        submitBtn.addEventListener('click', () => {
            alert('Booking request submitted. System is verifying resource availability and compliance policies.');
