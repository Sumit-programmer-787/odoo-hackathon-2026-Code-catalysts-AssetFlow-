<!DOCTYPE html>
<html lang="en" class="scroll-smooth">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>AssetFlow ERP | Resource Scheduling Console</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <script src="https://code.iconify.design/iconify-icon/1.0.7/iconify-icon.min.js"></script>
    <link href="https://fonts.googleapis.com/css2?family=Public+Sans:wght@300;400;500;600;700;800&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet">
    <style>
        :root {
            --charcoal: #1a1a1a;
            --graphite: #2a2a2a;
            --teal-accent: #10b981;
            --border-gray: #333333;
        }
        body {
            font-family: 'Public Sans', sans-serif;
            background-color: var(--charcoal);
            color: #e5e5e5;
            -webkit-font-smoothing: antialiased;
        }
        .mono { font-family: 'JetBrains Mono', monospace; font-variant-numeric: tabular-nums; }
        .industrial-border { border: 1px solid var(--border-gray); }
        .input-field {
            background-color: #111111;
            border: 1px solid var(--border-gray);
            height: 38px;
            padding: 0 12px;
            color: white;
            font-family: 'JetBrains Mono', monospace;
            font-size: 11px;
        }
    </style>
</head>
<body class="min-h-screen flex flex-col antialiased">

    <!-- Top Navigation Header -->
    <header class="h-12 bg-[#161616] industrial-border border-t-0 border-x-0 flex items-center justify-between px-6 z-50 shrink-0 relative">
        <div class="flex items-center gap-8">
            <div class="flex items-center gap-2">
                <div class="w-4 h-4 bg-[#10b981] flex items-center justify-center text-[10px] text-black font-black mono rounded-sm">⚡</div>
                <h1 class="text-xs font-black uppercase tracking-widest text-white mono">AssetFlow</h1>
            </div>
            <div class="text-[11px] mono text-gray-500">LOGISTICS MODULE // TIMELINE & RESOURCE SCHEDULING</div>
        </div>

        <!-- PROFILE AND USER MENU -->
        <div class="flex items-center gap-4 relative">
            <button id="notification-bell-btn" class="text-gray-400 hover:text-white relative h-8 w-8 flex items-center justify-center rounded hover:bg-[#222]">
                <iconify-icon icon="lucide:bell"></iconify-icon>
                <span class="absolute top-1.5 right-1.5 w-2 h-2 bg-red-500 rounded-full"></span>
            </button>
            <div class="h-4 w-[1px] bg-[#333]"></div>
            <div class="relative">
                <button id="user-profile-btn" class="flex items-center gap-2 text-left group focus:outline-none">
                    <div class="w-6 h-6 rounded-sm bg-[#2a2a2a] industrial-border flex items-center justify-center font-bold text-[10px] text-gray-300">AM</div>
                    <div class="hidden md:block">
                        <p class="text-[10px] font-bold text-gray-300 leading-none">A. MILLER</p>
                        <p class="text-[9px] text-[#10b981] mono leading-none mt-0.5">SYS-ADMIN</p>
                    </div>
                </button>
                <div id="profile-dropdown" class="absolute right-0 top-10 w-44 bg-[#161616] border border-[#333] shadow-2xl rounded-sm hidden z-50 flex flex-col overflow-hidden">
                    <div class="p-2.5 border-b border-[#252525] bg-[#1c1c1c]">
                        <p class="text-[9px] font-bold text-gray-500 mono uppercase tracking-wider">Access Node</p>
                        <p class="text-[11px] font-mono text-gray-300 truncate">miller@assetflow.corp</p>
                    </div>
                    <a href="/auth/logout" class="p-2.5 text-[11px] text-red-400 hover:bg-red-500/10 hover:text-red-300 transition-colors flex items-center gap-2 font-medium mono">
                        <iconify-icon icon="lucide:log-out"></iconify-icon>Terminate Session
                    </a>
                </div>
            </div>
        </div>
    </header>

    <div class="flex flex-1 min-h-0">
        <!-- Sidebar Navigation -->
        <aside class="w-64 bg-[#161616] industrial-border border-l-0 border-y-0 p-4 space-y-2">
            <p class="text-[9px] font-bold text-gray-500 uppercase tracking-widest px-3 mono">Management</p>
            <nav class="space-y-1 text-xs">
                <a href="/directory" class="flex items-center gap-3 px-3 py-2 text-gray-400 hover:bg-[#222] rounded-sm"><iconify-icon icon="lucide:layers"></iconify-icon>Asset Directory</a>
                <a href="#" class="flex items-center gap-3 px-3 py-2 bg-[#222] border border-[#333] text-white rounded-sm"><iconify-icon icon="lucide:calendar" class="text-[#10b981]"></iconify-icon>Resource Booking</a>
            </nav>
        </aside>

        <!-- Main Timelines Workspace Window -->
        <main class="flex-1 bg-[#1a1a1a] p-6 overflow-y-auto space-y-6">
            
            <!-- Timeline Grid View Block (SET TO CURRENT YEAR 2026) -->
            <div class="bg-[#161616] industrial-border rounded-sm p-4">
                <div class="flex justify-between items-center mb-4">
                    <div class="flex items-center gap-4">
                        <h3 class="text-xs uppercase font-black tracking-widest text-white mono">Master Resource Timeline</h3>
                        <div class="flex gap-3 text-[10px] mono">
                            <span class="text-blue-400">● Upcoming</span>
                            <span class="text-[#10b981]">● Ongoing</span>
                            <span class="text-red-500">● Conflict</span>
                        </div>
                    </div>
                    <div class="flex items-center bg-[#111] border border-[#333] px-3 py-1 rounded-sm gap-4">
                        <span class="mono text-xs text-white uppercase font-bold">MAY 2026</span>
                        <div class="flex gap-2 text-gray-500"><button class="hover:text-white">←</button><button class="hover:text-white">→</button></div>
                    </div>
                </div>

                <div class="overflow-x-auto">
                    <table class="w-full text-left border-collapse text-xs">
                        <thead>
                            <tr class="bg-[#1c1c1c] border-b border-[#2d2d2d] text-[10px] uppercase font-bold text-gray-400 mono">
                                <th class="p-3 w-40">Resource Unit</th>
                                <th class="p-3">May 01</th>
                                <th class="p-3">May 02</th>
                                <th class="p-3">May 03</th>
                                <th class="p-3">May 04</th>
                                <th class="p-3">May 05</th>
                            </tr>
                        </thead>
                        <tbody class="divide-y divide-[#252525] mono">
                            <tr>
                                <td class="p-3 font-bold text-gray-300">#LT-7729-A</td>
                                <td class="p-3 bg-blue-500/10 text-blue-400 border border-blue-500/20">#BK-901<br><span class="text-[9px] text-gray-500">Upcoming</span></td>
                                <td class="p-3 bg-emerald-500/10 text-[#10b981] border border-emerald-500/20">#DR-09-AIR<br><span class="text-[9px] text-gray-500">Ongoing</span></td>
                                <td class="p-3 bg-red-500/10 text-red-400 border border-red-500/20 font-bold">⚠️ COLLISION<br><span class="text-[9px] text-red-500">Overlapped</span></td>
                                <td class="p-3 text-gray-600">—</td>
                                <td class="p-3 text-gray-600">—</td>
                            </tr>
                        </tbody>
                    </table>
                </div>
            </div>

            <!-- Forms Workspace Splitting Layout Grid -->
            <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
                <!-- Reservation Inputs Block -->
                <div class="lg:col-span-2 bg-[#161616] industrial-border p-5 rounded-sm space-y-4">
                    <h3 class="text-xs uppercase font-black tracking-widest text-white mono border-b border-[#2a2a2a] pb-2">New Reservation Request</h3>
                    <form class="grid grid-cols-1 sm:grid-cols-2 gap-4">
                        <div class="space-y-1">
                            <label class="text-[10px] font-bold text-gray-400 uppercase tracking-widest mono">Select Target Resource</label>
                            <input type="text" class="input-field w-full rounded-sm" value="#LT-7729-A (Panasonic Toughbook)" readonly>
                        </div>
                        <div class="space-y-1">
                            <label class="text-[10px] font-bold text-gray-400 uppercase tracking-widest mono">Requestor Identifier (Email)</label>
                            <input type="email" class="input-field w-full rounded-sm" value="s.chen@assetflow.corp" readonly>
                        </div>
                        <div class="space-y-1">
                            <label class="text-[10px] font-bold text-gray-400 uppercase tracking-widest mono">Start Timestamp</label>
                            <input type="datetime-local" class="input-field w-full rounded-sm" value="2026-05-04T09:00">
                        </div>
                        <div class="space-y-1">
                            <label class="text-[10px] font-bold text-gray-400 uppercase tracking-widest mono">End Timestamp</label>
                            <input type="datetime-local" class="input-field w-full rounded-sm" value="2026-05-06T18:00">
                        </div>
                        <div class="sm:col-span-2 flex justify-end gap-3 pt-2">
                            <button type="button" class="px-4 py-2 bg-[#222] border border-[#333] text-xs font-bold text-gray-300 uppercase hover:text-white rounded-sm">Discard</button>
                            <button type="submit" class="px-4 py-2 bg-[#10b981] text-black text-xs font-black uppercase hover:bg-[#0d9469] rounded-sm">Initialize Booking</button>
                        </div>
                    </form>
                </div>

                <!-- Collision Detection Side Panel Logs (SET TO CURRENT YEAR 2026) -->
                <div class="bg-[#161616] industrial-border p-5 rounded-sm space-y-4">
                    <h3 class="text-xs uppercase font-black tracking-widest text-white mono border-b border-[#2a2a2a] pb-2">Conflict Detection Report</h3>
                    <div class="space-y-3">
                        <div class="p-3 bg-red-500/5 border border-red-500/20 rounded-sm">
                            <div class="flex items-center gap-2 text-red-400 font-bold text-[10px] uppercase mono mb-1">
                                <iconify-icon icon="lucide:alert-triangle"></iconify-icon>Critical Overlap
                            </div>
                            <p class="text-[11px] text-gray-400 leading-relaxed">MAY 05 detected as over-allocated for unit #LT-7729-A.</p>
                        </div>
                        <div class="p-3 bg-[#111] border border-[#2d2d2d] rounded-sm flex justify-between items-center">
                            <div>
                                <p class="text-[9px] uppercase font-bold text-gray-500 mono">Existing Booking</p>
                                <p class="text-xs text-white font-medium font-mono mt-0.5">#BK-901 / Marcus Vance</p>
                                <p class="text-[10px] text-gray-500 mono mt-1">ENDS: 2026-05-05 17:00</p>
                            </div>
                            <span class="status-pill bg-emerald-500/10 text-[#10b981] border border-emerald-500/20">Ongoing</span>
                        </div>
                    </div>
                </div>
            </div>
        </main>
    </div>

    <script>
        // Profile Dropdown Menu Interaction Block
        const profileBtn = document.getElementById('user-profile-btn');
        const profileDropdown = document.getElementById('profile-dropdown');

        profileBtn.addEventListener('click', (e) => {
            e.stopPropagation();
            profileDropdown.classList.toggle('hidden');
        });

        document.addEventListener('click', (e) => {
            if (!profileDropdown.contains(e.target) && e.target !== profileBtn) {
                profileDropdown.classList.add('hidden');
            }
        });
    </script>
</body>
</html>