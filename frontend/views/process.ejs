    <link href="https://fonts.googleapis.com/css2?family=Public+Sans:wght@300;400;500;600;700;800&amp;family=JetBrains+Mono:wght@400;500&amp;display=swap" rel="stylesheet">
    <style>
        :root {
            --charcoal: #0a0a0a;
            --graphite: #161616;
            --teal-accent: #10b981;
            --border-gray: #2a2a2a;
        }

        body {
            font-family: 'Public Sans', sans-serif;
            background-color: var(--charcoal);
            color: #e5e5e5;
            -webkit-font-smoothing: antialiased;
        }

        .mono {
            font-family: 'JetBrains Mono', monospace;
            font-variant-numeric: tabular-nums;
        }

        .industrial-border {
            border: 1px solid var(--border-gray);
        }

        /* 3D Scene Config */
        .perspective-scene {
            perspective: 1200px;
        }

        .flow-container {
            transform-style: preserve-3d;
            transform: rotateX(15deg) rotateY(-5deg);
            transition: transform 0.5s ease;
        }

        .flow-container:hover {
            transform: rotateX(10deg) rotateY(0deg);
        }

        .node-card {
            transform-style: preserve-3d;
            transition: transform 0.3s ease, box-shadow 0.3s ease;
        }

        .node-card:hover {
            transform: translateZ(20px);
        }

        .node-glow {
            filter: drop-shadow(0 0 15px currentColor);
        }

        .line-animate {
            stroke-dasharray: 10;
            animation: dash 30s linear infinite;
        }

        @keyframes dash {
            to { stroke-dashoffset: -1000; }
        }

        .pulse-active {
            animation: pulse-ring 2s cubic-bezier(0.4, 0, 0.6, 1) infinite;
        }

        @keyframes pulse-ring {
            0% { transform: scale(0.95); opacity: 0.8; }
            50% { transform: scale(1.05); opacity: 0.4; }
            100% { transform: scale(0.95); opacity: 0.8; }
        }

        /* Custom Scrollbar */
        ::-webkit-scrollbar { width: 5px; height: 5px; }
        ::-webkit-scrollbar-track { background: var(--charcoal); }
        ::-webkit-scrollbar-thumb { background: var(--border-gray); border-radius: 0px; }
        ::-webkit-scrollbar-thumb:hover { background: var(--teal-accent); }
    </style>
</head>
