        :root {
            --charcoal: #1a1a1a;
            --graphite: #2a2a2a;
            --teal-accent: #10b981;
            --border-gray: #333333;
        }

        body {
            font-family: 'Public Sans', sans-serif;
            background-color: var(--charcoal);
            color: #e5e5e5;
            -webkit-font-smoothing: antialiased;
        }

        .mono {
            font-family: 'JetBrains Mono', monospace;
            font-variant-numeric: tabular-nums;
        }

        .industrial-border {
            border: 1px solid var(--border-gray);
        }

        .btn-action {
            @apply flex items-center gap-2 px-3 py-1.5 text-xs font-bold uppercase tracking-wider transition-all duration-200 border rounded-[2px];
        }

        .status-pill {
            @apply px-2 py-0.5 text-[10px] font-bold uppercase tracking-tighter rounded-[2px] inline-flex items-center;
        }

        /* Overdue Table Specifics */
        .row-urgent { background-color: rgba(239, 68, 68, 0.05); }
        .row-warning { background-color: rgba(245, 158, 11, 0.05); }

        /* Custom Scrollbar */
        ::-webkit-scrollbar { width: 4px; height: 4px; }
        ::-webkit-scrollbar-track { background: var(--charcoal); }
        ::-webkit-scrollbar-thumb { background: var(--border-gray); }
        ::-webkit-scrollbar-thumb:hover { background: var(--teal-accent); }

        /* Hide elements for Login State Simulation */
        .logged-out .auth-only { display: none !important; }
        .logged-in .guest-only { display: none !important; }
    </style>
</head>
