    <script>
        // Sidebar Toggle Logic
        const sidebar = document.getElementById('sidebar');
        const sidebarToggle = document.getElementById('sidebar-toggle');
        let isExpanded = true;

        sidebarToggle.addEventListener('click', () => {
            if (isExpanded) {
                sidebar.style.width = '64px';
                // Hide labels manually for smooth transition simulation
                document.querySelectorAll('#sidebar span, #sidebar p, #sidebar h1').forEach(el => el.classList.add('hidden'));
            } else {
                sidebar.style.width = '256px';
                document.querySelectorAll('#sidebar span, #sidebar p, #sidebar h1').forEach(el => el.classList.remove('hidden'));
            }
            isExpanded = !isExpanded;
        });

        // Simple Login Modal Toggle for Demo
        const profileBtn = document.getElementById('user-profile-btn');
        const loginModal = document.getElementById('login-modal');
        const closeLogin = document.getElementById('close-login');

        profileBtn.addEventListener('click', () => {
            if (document.body.classList.contains('logged-out')) {
                loginModal.classList.remove('hidden');
            } else {
                // Simulate logout
                if (confirm('Terminate operational session?')) {
                    document.body.classList.remove('logged-in');
                    document.body.classList.add('logged-out');
                }
            }
        });

        closeLogin.addEventListener('click', () => {
            loginModal.classList.add('hidden');
        });

        // Initialize state for demo
        document.body.classList.add('logged-in');
    </script>

