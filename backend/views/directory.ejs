    <style>
        :root {
            --charcoal: #1a1a1a;
            --graphite: #2a2a2a;
            --teal-accent: #10b981;
            --border-gray: #333333;
        }

        body {
            font-family: 'Public Sans', sans-serif;
            background-color: var(--charcoal);
            color: #e5e5e5;
            -webkit-font-smoothing: antialiased;
        }

        .mono {
            font-family: 'JetBrains Mono', monospace;
            font-variant-numeric: tabular-nums;
        }

        .industrial-border {
            border: 1px solid var(--border-gray);
        }

        .input-field {
            @apply bg-[#161616] border border-[#333] px-3 py-1.5 text-xs text-white focus:outline-none focus:border-[#10b981] transition-colors rounded-[2px];
        }

        .status-pill {
            @apply px-2 py-0.5 text-[10px] font-bold uppercase tracking-tighter rounded-[2px] inline-flex items-center;
        }

        .tab-active {
            @apply border-b-2 border-[#10b981] text-white font-bold;
        }

        .tab-inactive {
            @apply text-gray-500 hover:text-white transition-colors;
        }

        /* Drawer Transition */
        #asset-drawer {
            transition: transform 0.3s cubic-bezier(0.4, 0, 0.2, 1);
        }

        /* Custom Scrollbar */
        ::-webkit-scrollbar { width: 4px; height: 4px; }
        ::-webkit-scrollbar-track { background: var(--charcoal); }
        ::-webkit-scrollbar-thumb { background: var(--border-gray); }
        ::-webkit-scrollbar-thumb:hover { background: var(--teal-accent); }
    </style>
</head>
