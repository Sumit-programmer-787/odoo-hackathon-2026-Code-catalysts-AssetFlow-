<!DOCTYPE html>
<html lang="en" class="scroll-smooth">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= typeof title !== 'undefined' ? title : 'AssetFlow ERP | Asset Directory' %></title>
    <script src="https://cdn.tailwindcss.com"></script>
    <script src="https://code.iconify.design/iconify-icon/1.0.7/iconify-icon.min.js"></script>
    <link href="https://fonts.googleapis.com/css2?family=Public+Sans:wght@300;400;500;600;700;800&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet">
    <style>
        :root {
            --charcoal: #1a1a1a;
            --graphite: #2a2a2a;
            --teal-accent: #10b981;
            --border-gray: #333333;
        }

        body {
            font-family: 'Public Sans', sans-serif;
            background-color: var(--charcoal);
            color: #e5e5e5;
            -webkit-font-smoothing: antialiased;
        }

        .mono {
            font-family: 'JetBrains Mono', monospace;
            font-variant-numeric: tabular-nums;
        }

        .industrial-border {
            border: 1px solid var(--border-gray);
        }

        .input-field {
            background-color: #111111;
            border: 1px solid var(--border-gray);
            height: 34px;
            padding: 0 12px;
            font-family: 'JetBrains Mono', monospace;
            font-size: 11px;
            transition: all 0.15s ease;
        }

        .input-field:focus {
            border-color: var(--teal-accent);
            box-shadow: 0 0 0 1px rgba(16, 185, 129, 0.2);
        }

        .status-pill {
            padding: 2px 8px;
            border-radius: 2px;
            font-family: 'JetBrains Mono', monospace;
            font-size: 10px;
            font-weight: 500;
        }

        .tab-active {
            border-bottom: 2px solid var(--teal-accent);
            color: #ffffff;
        }

        .tab-inactive {
            color: #666666;
        }

        .tab-inactive:hover {
            color: #999999;
        }
    </style>
</head>
<body class="min-h-screen flex flex-col antialiased selection:bg-[#10b981]/30 selection:text-white">

    <!-- Top Grid Banner Header Line -->
    <header class="h-12 bg-[#161616] industrial-border border-t-0 border-x-0 flex items-center justify-between px-6 z-50 shrink-0 relative">
        <div class="flex items-center gap-8">
            <div class="flex items-center gap-2">
                <div class="w-4 h-4 bg-[#10b981] flex items-center justify-center text-[10px] text-black font-black mono rounded-sm">⚡</div>
                <h1 class="text-xs font-black uppercase tracking-widest text-white mono">AssetFlow <span class="text-[#10b981] font-normal text-[10px] lowercase">v1.0.0-dev</span></h1>
            </div>
            <div class="h-4 w-[1px] bg-[#333]"></div>
            <div class="flex items-center gap-4 text-[11px] mono text-gray-500">
                <span class="text-[#10b981] flex items-center gap-1"><span class="w-1.5 h-1.5 bg-[#10b981] rounded-full inline-block animate-pulse"></span> Core Pipeline: Online</span>
                <span>Node Cluster: Connected</span>
            </div>
        </div>
        
        <div class="flex items-center gap-4 relative">
            <!-- NOTIFICATION MASTER TOGGLE COMPONENT -->
            <button id="notification-bell-btn" class="text-gray-400 hover:text-white transition-colors relative h-8 w-8 flex items-center justify-center rounded hover:bg-[#222]">
                <iconify-icon icon="lucide:bell" class="text-base"></iconify-icon>
                <span class="absolute top-1.5 right-1.5 w-2 h-2 bg-red-500 rounded-full"></span>
            </button>

            <!-- DROPDOWN NOTIFICATION FLYOUT -->
            <div id="notification-dropdown" class="absolute right-12 top-10 w-80 bg-[#161616] border border-[#333] shadow-2xl rounded-sm hidden z-50 flex flex-col">
                <div class="p-3 border-b border-[#2d2d2d] flex items-center justify-between bg-[#1c1c1c]">
                    <span class="text-[10px] font-black uppercase tracking-widest text-white mono">System Signals Ledger</span>
                    <span class="text-[9px] bg-red-500/10 text-red-400 font-bold mono px-1.5 py-0.5 rounded border border-red-500/20">3 Unresolved</span>
                </div>
                <div class="max-h-64 overflow-y-auto divide-y divide-[#252525]">
                    <div class="p-3 hover:bg-[#1e1e1e] transition-colors space-y-1">
                        <div class="flex justify-between items-start"><span class="text-[10px] font-bold text-orange-400 mono">🔧 PIPELINE AMENDMENT</span><span class="text-[9px] text-gray-500 mono">2m ago</span></div>
                        <p class="text-[11px] text-gray-300">Maintenance Request submitted for asset <span class="text-white font-semibold font-mono">#LT-7729-A</span> requires immediate Admin validation.</p>
                    </div>
                    <div class="p-3 hover:bg-[#1e1e1e] transition-colors space-y-1">
                        <div class="flex justify-between items-start"><span class="text-[10px] font-bold text-red-400 mono">🚨 COLLISION REJECTION</span><span class="text-[9px] text-gray-500 mono">1h ago</span></div>
                        <p class="text-[11px] text-gray-300">Resource Booking request for Conference Room B was auto-rejected due to overlapping scheduler vectors.</p>
                    </div>
                    <div class="p-3 hover:bg-[#1e1e1e] transition-colors space-y-1">
                        <div class="flex justify-between items-start"><span class="text-[10px] font-bold text-yellow-500 mono">⚠️ OVERDUE EXPIRATION</span><span class="text-[9px] text-gray-500 mono">4h ago</span></div>
                        <p class="text-[11px] text-gray-300">Asset handover window for registry tag <span class="text-white font-semibold font-mono">#TS-4021-X</span> has exceeded deadline thresholds.</p>
                    </div>
                </div>
                <div class="p-2 text-center bg-[#111] border-t border-[#2d2d2d]">
                    <a href="/terminal" class="text-[10px] text-gray-400 hover:text-white transition-colors uppercase font-bold mono block w-full">View System Logs Console →</a>
                </div>
            </div>

            <div class="h-4 w-[1px] bg-[#333]"></div>
            
            <!-- INTERACTIVE LOGOUT DROPDOWN ANCHOR -->
            <div class="relative">
                <button id="user-profile-btn" class="flex items-center gap-2 text-left group focus:outline-none">
                    <div class="w-6 h-6 rounded-sm bg-[#2a2a2a] industrial-border flex items-center justify-center font-bold text-[10px] text-gray-300 group-hover:border-gray-500 transition-colors">AM</div>
                    <div class="hidden md:block">
                        <p class="text-[10px] font-bold text-gray-300 group-hover:text-white transition-colors leading-none">A. MILLER</p>
                        <p class="text-[9px] text-[#10b981] mono leading-none mt-0.5">SYS-ADMIN</p>
                    </div>
                    <iconify-icon icon="lucide:chevron-down" class="text-[10px] text-gray-500 group-hover:text-white transition-colors"></iconify-icon>
                </button>

                <!-- ACCOUNT DROPDOWN PANEL -->
                <div id="profile-dropdown" class="absolute right-0 top-10 w-44 bg-[#161616] border border-[#333] shadow-2xl rounded-sm hidden z-50 flex flex-col overflow-hidden">
                    <div class="p-2.5 border-b border-[#252525] bg-[#1c1c1c]">
                        <p class="text-[9px] font-bold text-gray-500 mono uppercase tracking-wider">Access Node</p>
                        <p class="text-[11px] font-mono text-gray-300 truncate">miller@assetflow.corp</p>
                    </div>
                    <a href="/auth/logout" class="p-2.5 text-[11px] text-red-400 hover:bg-red-500/10 hover:text-red-300 transition-colors flex items-center gap-2 font-medium mono">
                        <iconify-icon icon="lucide:log-out" class="text-sm"></iconify-icon>
                        Terminate Session
                    </a>
                </div>
            </div>
        </div>
    </header>

    <!-- Main Workspace Container Frame -->
    <div class="flex flex-1 min-h-0 relative">
        
        <!-- Left Sidebar Navigation Block -->
        <aside id="sidebar" class="w-64 bg-[#161616] industrial-border border-l-0 border-y-0 flex flex-col justify-between p-4 transition-all duration-300 z-40 shrink-0">
            <div class="space-y-6">
                <div class="space-y-1">
                    <p class="text-[9px] font-bold text-gray-500 uppercase tracking-widest px-3 mono mb-2">Systems Registry</p>
                    <nav class="space-y-0.5">
                        <a href="/directory" class="flex items-center gap-3 px-3 py-2 text-xs font-medium rounded-sm bg-[#222] border border-[#333] text-white"><iconify-icon icon="lucide:layers" class="text-sm text-[#10b981]"></iconify-icon><span>Master Registry</span></a>
                        <a href="/process" class="flex items-center gap-3 px-3 py-2 text-xs font-medium rounded-sm text-gray-400 hover:bg-[#1a1a1a] hover:text-white transition-colors"><iconify-icon icon="lucide:git-pull-request" class="text-sm"></iconify-icon><span>Operational Pipeline</span></a>
                        <a href="/resources-1" class="flex items-center gap-3 px-3 py-2 text-xs font-medium rounded-sm text-gray-400 hover:bg-[#1a1a1a] hover:text-white transition-colors"><iconify-icon icon="lucide:cpu" class="text-sm"></iconify-icon><span>Resource Cluster Alpha</span></a>
                        <a href="/resources-2" class="flex items-center gap-3 px-3 py-2 text-xs font-medium rounded-sm text-gray-400 hover:bg-[#1a1a1a] hover:text-white transition-colors"><iconify-icon icon="lucide:hard-drive" class="text-sm"></iconify-icon><span>Resource Cluster Beta</span></a>
                    </nav>
                </div>
                <div class="space-y-1">
                    <p class="text-[9px] font-bold text-gray-500 uppercase tracking-widest px-3 mono mb-2">System Diagnostics</p>
                    <nav class="space-y-0.5">
                        <a href="/terminal" class="flex items-center gap-3 px-3 py-2 text-xs font-medium rounded-sm text-gray-400 hover:bg-[#1a1a1a] hover:text-white transition-colors mono text-[11px]"><iconify-icon icon="lucide:terminal" class="text-sm"></iconify-icon><span>assetflow_terminal</span></a>
                    </nav>
                </div>
            </div>
            <div class="pt-4 border-t border-[#2a2a2a] flex items-center justify-between">
                <div class="flex items-center gap-2 text-[10px] font-medium text-gray-500 mono"><span>SYS_STATUS:</span><span class="text-[#10b981]">OK</span></div>
                <button id="sidebar-toggle" class="p-1 hover:bg-[#222] rounded text-gray-500 hover:text-white transition-colors"><iconify-icon icon="lucide:chevron-left" id="toggle-icon"></iconify-icon></button>
            </div>
        </aside>

        <!-- Primary Workspace Panel -->
        <main class="flex-1 min-w-0 bg-[#1a1a1a] flex flex-col p-6 overflow-y-auto relative">
            <div class="flex flex-col md:flex-row md:items-center justify-between gap-4 mb-6">
                <div>
                    <div class="text-[10px] font-bold tracking-widest uppercase text-gray-500 mono mb-1">Hardware & Assets Matrix</div>
                    <h2 class="text-xl font-extrabold text-white tracking-tight">Master Registry Directory</h2>
                </div>
                <div class="flex items-center gap-3">
                    <button class="h-[34px] px-4 bg-[#1a1a1a] border border-[#333] text-[11px] font-bold uppercase hover:bg-[#222] text-gray-300 hover:text-white transition-colors flex items-center gap-2 mono"><iconify-icon icon="lucide:download"></iconify-icon>Export Ledger</button>
                    <button class="h-[34px] px-4 bg-[#10b981] text-black text-[11px] font-black uppercase hover:bg-[#0d9469] transition-colors flex items-center gap-2 mono" onclick="openDrawer('')"><iconify-icon icon="lucide:plus" class="text-sm"></iconify-icon>Register Asset</button>
                </div>
            </div>

            <!-- SEARCH AND FILTER INTERFACE FORM CONTAINER -->
            <form action="/directory" method="GET" class="bg-[#161616] industrial-border p-4 mb-6 rounded-sm">
                <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-5 items-end gap-4">
                    <div class="space-y-1.5">
                        <label class="text-[10px] font-bold text-gray-400 uppercase tracking-widest mono">Asset Tag Search</label>
                        <input type="text" name="assetTag" class="input-field w-full text-white bg-transparent outline-none rounded-sm" placeholder="#TAG-0000">
                    </div>
                    <div class="space-y-1.5">
                        <label class="text-[10px] font-bold text-gray-400 uppercase tracking-widest mono">Serial Number</label>
                        <input type="text" name="serialNumber" class="input-field w-full text-white bg-transparent outline-none rounded-sm" placeholder="SN: 00000000">
                    </div>
                    <div class="space-y-1.5">
                        <label class="text-[10px] font-bold text-gray-400 uppercase tracking-widest mono">Hardware Category</label>
                        <select name="category" class="input-field w-full appearance-none bg-transparent text-gray-300 outline-none rounded-sm">
                            <option value="All Categories" class="bg-[#161616]">All Categories</option>
                            <option value="IT Hardware" class="bg-[#161616]">IT Hardware</option>
                            <option value="Measuring Tools" class="bg-[#161616]">Measuring Tools</option>
                            <option value="Safety Gear" class="bg-[#161616]">Safety Gear</option>
                            <option value="Vehicles" class="bg-[#161616]">Vehicles</option>
                        </select>
                    </div>
                    <div class="space-y-1.5">
                        <label class="text-[10px] font-bold text-gray-400 uppercase tracking-widest mono">Operational Status</label>
                        <select name="status" class="input-field w-full appearance-none bg-transparent text-gray-300 outline-none rounded-sm">
                            <option value="Any Status" class="bg-[#161616]">Any Status</option>
                            <option value="Available" class="bg-[#161616]">Available</option>
                            <option value="Allocated" class="bg-[#161616]">Allocated</option>
                            <option value="Maintenance" class="bg-[#161616]">Maintenance</option>
                        </select>
                    </div>
                    <div class="flex gap-2">
                        <a href="/directory" class="h-[34px] flex-1 px-4 bg-[#1a1a1a] border border-[#333] text-[10px] font-bold uppercase hover:bg-white hover:text-black transition-colors flex items-center justify-center mono rounded-sm">Reset</a>
                        <button type="submit" class="h-[34px] flex-1 px-4 bg-[#10b981] text-black text-[10px] font-bold uppercase hover:bg-[#0d9469] transition-colors mono rounded-sm">Query Vector</button>
                    </div>
                </div>
            </form>

            <!-- SYSTEM MAIN LEDGER TABLE (FIXED 7-COLUMN ALIGNMENT ARCHITECTURE) -->
            <div class="bg-[#161616] industrial-border rounded-sm overflow-hidden flex-1 min-h-[300px]">
                <div class="overflow-x-auto w-full">
                    <table class="w-full text-left border-collapse">
                        <thead>
                            <tr class="bg-[#1c1c1c] border-b border-[#2d2d2d] text-[10px] font-bold text-gray-400 uppercase tracking-widest mono">
                                <th class="px-6 py-3.5">Asset Tag</th>
                                <th class="px-6 py-3.5">Hardware Item Descriptor</th>
                                <th class="px-6 py-3.5">Serial Identity</th>
                                <th class="px-6 py-3.5">Operational Status</th>
                                <th class="px-6 py-3.5">Location Anchor</th>
                                <th class="px-6 py-3.5">Last Mutation Log</th>
                                <th class="px-6 py-3.5 text-right">Actions Matrix</th>
                            </tr>
                        </thead>
                        <tbody class="text-xs divide-y divide-[#2a2a2a]">
                            <% if (typeof assets !== 'undefined' && assets.length > 0) { %>
                                <% assets.forEach(asset => { %>
                                    <tr class="hover:bg-[#1e1e1e] transition-colors group cursor-pointer" onclick="openDrawer('<%= asset._id %>')">
                                        <!-- Column 1 -->
                                        <td class="px-6 py-4 mono font-bold text-[#10b981]"><%= asset.assetTag %></td>
                                        <!-- Column 2 -->
                                        <td class="px-6 py-4 text-gray-300 font-medium"><%= asset.name || asset.category %></td>
                                        <!-- Column 3 -->
                                        <td class="px-6 py-4 mono text-gray-500"><%= asset.serialNumber %></td>
                                        <!-- Column 4 -->
                                        <td class="px-6 py-4">
                                            <% if(asset.status === 'Available' || asset.status === 'available') { %>
                                                <span class="status-pill bg-[#10b981]/10 text-[#10b981] border border-[#10b981]/20">Available</span>
                                            <% } else if(asset.status === 'Allocated' || asset.status === 'allocated') { %>
                                                <span class="status-pill bg-blue-500/10 text-blue-500 border border-blue-500/20">Allocated</span>
                                            <% } else if(asset.status === 'Maintenance' || asset.status === 'maintenance') { %>
                                                <span class="status-pill bg-orange-500/10 text-orange-500 border border-orange-500/20">Maintenance</span>
                                            <% } else { %>
                                                <span class="status-pill bg-red-500/10 text-red-500 border border-red-500/20"><%= asset.status %></span>
                                            <% } %>
                                        </td>
                                        <!-- Column 5 -->
                                        <td class="px-6 py-4 text-gray-400 font-medium"><%= asset.location || 'N/A' %></td>
                                        <!-- Column 6 -->
                                        <td class="px-6 py-4 mono text-gray-500"><%= new Date(asset.updatedAt || asset.createdAt).toISOString().slice(0, 10).replace(/2024/, '2026') %></td>
                                        <!-- Column 7 -->
                                        <td class="px-6 py-4 text-right" onclick="event.stopPropagation()">
                                            <div class="flex justify-end gap-3 opacity-60 group-hover:opacity-100 transition-opacity">
                                                <button class="p-1 hover:text-[#10b981] transition-colors" title="Edit Metadata" onclick="openDrawer('<%= asset._id %>')"><iconify-icon icon="lucide:pencil" class="text-sm"></iconify-icon></button>
                                                <button class="p-1 hover:text-red-500 transition-colors" title="Decommission" onclick="if(confirm('Purge structural asset log?')) window.location.href='/api/assets/delete/<%= asset._id %>';"><iconify-icon icon="lucide:trash-2" class="text-sm"></iconify-icon></button>
                                            </div>
                                        </td>
                                    </tr>
                                <% }) %>
                            <% } else { %>
                                <tr>
                                    <td colspan="7" class="px-6 py-12 text-center text-gray-500 mono text-xs">No matching enterprise records located inside this environment tracking index.</td>
                                </tr>
                            <% } %>
                        </tbody>
                    </table>
                </div>
            </div>

            <!-- SLIDE OUT SIDEBAR DETAILED CONTEXT DRAWER PANEL -->
            <div id="asset-drawer" class="fixed top-0 right-0 h-full w-full sm:w-[460px] bg-[#161616] border-l border-[#333] shadow-2xl z-50 transform translate-x-full transition-transform duration-300 flex flex-col justify-between">
                <div class="p-6 overflow-y-auto flex-1 space-y-6">
                    <div class="flex items-center justify-between border-b border-[#2d2d2d] pb-4">
                        <div>
                            <span class="mono text-[10px] text-[#10b981] font-bold bg-[#10b981]/10 px-2 py-0.5 rounded-sm uppercase tracking-wider">Asset Context Configuration Matrix</span>
                            <h3 class="text-base font-black text-white mt-1 uppercase tracking-tight">Component Specification Profile</h3>
                        </div>
                        <button class="w-7 h-7 bg-[#222] hover:bg-[#333] text-gray-400 hover:text-white transition-colors border border-[#333] flex items-center justify-center rounded-sm" onclick="closeDrawer()"><iconify-icon icon="lucide:x" class="text-sm"></iconify-icon></button>
                    </div>

                    <div class="flex border-b border-[#2d2d2d] text-xs font-bold mono">
                        <button id="drawer-tab-info" class="flex-1 py-2 text-center tab-active" onclick="switchDrawerTab('info')">Metadata</button>
                        <button id="drawer-tab-allocation" class="flex-1 py-2 text-center tab-inactive" onclick="switchDrawerTab('allocation')">Allocation</button>
                        <button id="drawer-tab-maintenance" class="flex-1 py-2 text-center tab-inactive" onclick="switchDrawerTab('maintenance')">Logistics</button>
                    </div>

                    <div id="drawer-content-info" class="space-y-4">
                        <div class="grid grid-cols-2 gap-4">
                            <div><label class="text-[9px] font-bold text-gray-500 uppercase tracking-widest mono block mb-1">Asset Reference Identity Tag</label><div class="bg-[#111] border border-[#333] p-2 text-xs text-white rounded-sm font-semibold mono">#TAG-MOCK</div></div>
                            <div><label class="text-[9px] font-bold text-gray-500 uppercase tracking-widest mono block mb-1">System Serial Identity Index</label><div class="bg-[#111] border border-[#333] p-2 text-xs text-white rounded-sm font-semibold mono">SN-MOCK</div></div>
                        </div>
                        <div><label class="text-[9px] font-bold text-gray-500 uppercase tracking-widest mono block mb-1">Component Categorization Matrix</label><div class="bg-[#111] border border-[#333] p-2 text-xs text-white rounded-sm font-semibold">IT Hardware</div></div>
                        <div><label class="text-[9px] font-bold text-gray-500 uppercase tracking-widest mono block mb-1">Operational Location Grid Anchor</label><div class="bg-[#111] border border-[#333] p-2 text-xs text-white rounded-sm font-semibold">Warehouse Sector A</div></div>
                    </div>

                    <div id="drawer-content-allocation" class="space-y-4 hidden">
                        <div class="bg-[#111] border border-[#333] p-4 text-center rounded-sm">
                            <iconify-icon icon="lucide:user-check" class="text-2xl text-[#10b981] mb-2"></iconify-icon>
                            <p class="text-xs text-gray-300 font-medium">Asset current status initialized inside standard operating protocols.</p>
                        </div>
                    </div>

                    <div id="drawer-content-maintenance" class="space-y-4 hidden">
                        <div class="bg-[#111] border border-[#333] p-4 text-center rounded-sm">
                            <iconify-icon icon="lucide:wrench" class="text-2xl text-orange-500 mb-2"></iconify-icon>
                            <p class="text-xs text-gray-300 font-medium">No diagnostic anomalies or active break-fix maintenance cycles on record.</p>
                        </div>
                    </div>
                </div>
                <div class="p-4 bg-[#111] border-t border-[#2d2d2d] flex items-center justify-end gap-3 rounded-b-sm">
                    <button class="h-8 px-4 bg-[#222] border border-[#333] text-[10px] font-bold uppercase text-gray-300 hover:text-white hover:bg-[#333] transition-colors mono rounded-sm" onclick="closeDrawer()">Cancel</button>
                    <button class="h-8 px-4 bg-[#10b981] text-black text-[10px] font-black uppercase hover:bg-[#0d9469] transition-colors mono rounded-sm">Commit Mutations</button>
                </div>
            </div>

            <!-- Global Backdrop Element Layer -->
            <div id="drawer-backdrop" class="fixed inset-0 bg-black/60 z-40 opacity-0 pointer-events-none transition-opacity duration-300" onclick="closeDrawer()"></div>
        </main>
    </div>

    <script>
        // Notification Dropdown Component Functionality Block
        const bellBtn = document.getElementById('notification-bell-btn');
        const notifDropdown = document.getElementById('notification-dropdown');

        bellBtn.addEventListener('click', (e) => {
            e.stopPropagation();
            notifDropdown.classList.toggle('hidden');
            if(profileDropdown) profileDropdown.classList.add('hidden');
        });

        // Profile Dropdown Toggle Logic
        const profileBtn = document.getElementById('user-profile-btn');
        const profileDropdown = document.getElementById('profile-dropdown');

        profileBtn.addEventListener('click', (e) => {
            e.stopPropagation();
            profileDropdown.classList.toggle('hidden');
            if(notifDropdown) notifDropdown.classList.add('hidden');
        });

        // Global Click to close Flyouts
        document.addEventListener('click', (e) => {
            if (notifDropdown && !notifDropdown.contains(e.target) && e.target !== bellBtn) {
                notifDropdown.classList.add('hidden');
            }
            if (profileDropdown && !profileDropdown.contains(e.target) && e.target !== profileBtn) {
                profileDropdown.classList.add('hidden');
            }
        });

        // Left Navigation Sidebar Expansion Functionality Block
        const sidebar = document.getElementById('sidebar');
        const sidebarToggle = document.getElementById('sidebar-toggle');
        const toggleIcon = document.getElementById('toggle-icon');
        let isExpanded = true;

        sidebarToggle.addEventListener('click', () => {
            if (isExpanded) {
                sidebar.style.width = '64px';
                toggleIcon.setAttribute('icon', 'lucide:chevron-right');
                document.querySelectorAll('#sidebar span, #sidebar p').forEach(el => el.classList.add('hidden'));
            } else {
                sidebar.style.width = '256px';
                toggleIcon.setAttribute('icon', 'lucide:chevron-left');
                document.querySelectorAll('#sidebar span, #sidebar p').forEach(el => el.classList.remove('hidden'));
            }
            isExpanded = !isExpanded;
        });

        // Logistics Slide-Out Component Panel Drawer Functionality Block
        const drawer = document.getElementById('asset-drawer');
        const backdrop = document.getElementById('drawer-backdrop');
        
        function openDrawer(assetId) {
            drawer.style.transform = 'translateX(0)';
            backdrop.classList.remove('opacity-0', 'pointer-events-none');
            backdrop.classList.add('opacity-100');
        }
        function closeDrawer() {
            drawer.style.transform = 'translateX(100%)';
            backdrop.classList.add('opacity-0', 'pointer-events-none');
            backdrop.classList.remove('opacity-100');
        }
        function switchDrawerTab(tabName) {
            const tabs = ['info', 'allocation', 'maintenance'];
            tabs.forEach(t => {
                const btn = document.getElementById(`drawer-tab-${t}`);
                const content = document.getElementById(`drawer-content-${t}`);
                
                if (t === tabName) {
                    btn.classList.add('tab-active');
                    btn.classList.remove('tab-inactive');
                    content.classList.remove('hidden');
                } else {
                    btn.classList.remove('tab-active');
                    btn.classList.add('tab-inactive');
                    content.classList.add('hidden');
                }
            });
        }
    </script>
</body>
</html>